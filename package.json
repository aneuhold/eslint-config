{
  "name": "@aneuhold/eslint-config",
  "version": "2.0.6",
  "description": "Main ESLint Configuration for personal projects",
  "main": "./src/ts-lib-config.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "nodemon -e js --exec \"local-npm publish\"",
    "unpub": "local-npm unpublish",
    "pushpub": "pnpm version patch && git push",
    "upgrade:all": "pnpm update --latest",
    "lint": "pnpm eslint"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aneuhold/eslint-config.git"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "prettier"
  ],
  "author": "Anton G. Neuhold Jr.",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/aneuhold/eslint-config/issues"
  },
  "homepage": "https://github.com/aneuhold/eslint-config#readme",
  "files": [
    "src/**/*"
  ],
  "peerDependencies": {
    "eslint": ">= 10.2.1",
    "prettier": ">= 3.8.3"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@stylistic/eslint-plugin-js": "^4.4.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "angular-eslint": "^21.3.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-svelte": "^3.17.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "prettier-plugin-svelte": "^3.5.1",
    "typescript-eslint": "^8.59.0"
  },
  "devDependencies": {
    "@aneuhold/local-npm-registry": "^0.2.30",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "svelte": "^5.55.5",
    "typescript": "^6.0.3"
  }
}
